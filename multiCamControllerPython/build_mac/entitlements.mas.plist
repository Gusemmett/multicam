<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <!-- Required: App Sandbox -->
  <key>com.apple.security.app-sandbox</key><true/>

  <!-- Network: Required for device discovery and communication -->
  <key>com.apple.security.network.client</key><true/>
  <key>com.apple.security.network.server</key><true/>

  <!-- File Access: Required for video file operations -->
  <key>com.apple.security.files.user-selected.read-write</key><true/>

  <!-- Local Network: Required for Bonjour/zeroconf device discovery -->
  <!-- This is implicit with NSLocalNetworkUsageDescription + NSBonjourServices in Info.plist -->
</dict></plist>
